  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren       Pesantren          @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  products        Product[]
  pos_sessions    PosSession[]
  pos_orders      PosOrder[]
  stock_movements StockMovement[]
  stock_opnames   StockOpname[]
  promotions      Promotion[]
  
  product_categories ProductCategory[]
  product_units      ProductUnit[]
  assigned_users  User[] @relation("UserOutlet")

  @@unique([tenant_uuid, name])
  @@index([tenant_uuid])
  @@map("koperasi_outlets")
}

model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  outlet_id   String?  @db.Uuid
  name        String
  icon        String?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren       @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet?  @relation(fields: [outlet_id], references: [id])
  products  Product[]

  @@unique([tenant_uuid, outlet_id, name])
  @@index([tenant_uuid])
  @@index([outlet_id])
  @@map("product_categories")
}

model ProductUnit {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  outlet_id   String?  @db.Uuid
  name        String   // pcs, kg, liter, pack, etc.
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren       @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet?  @relation(fields: [outlet_id], references: [id])
  products  Product[]

  @@unique([tenant_uuid, outlet_id, name])
  @@index([tenant_uuid])
  @@index([outlet_id])
  @@map("product_units")
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_uuid     String   @db.Uuid
  outlet_id       String   @db.Uuid
  category_id     String?  @db.Uuid
  unit_id         String?  @db.Uuid
  name            String
  sku             String?
  barcode         String?
  description     String?
  price           Decimal  @db.Decimal(12,2)     // Harga jual
  cost_price      Decimal  @default(0) @db.Decimal(12,2)  // HPP dari supplier
  margin_percent  Decimal  @default(0) @db.Decimal(5,2)   // Margin % 
  stock           Int      @default(0)
  min_stock       Int      @default(5)
  image_url       String?
  unit            String   @default("pcs") // pcs, kg, liter, pack (Deprecated in favor of unit_id but kept for compatibility)
  supplier_name   String?
  supplier_phone  String?
  is_active       Boolean  @default(true)
  track_stock     Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  pesantren       Pesantren         @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet          KoperasiOutlet    @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  category        ProductCategory?  @relation(fields: [category_id], references: [id])
  product_unit    ProductUnit?      @relation(fields: [unit_id], references: [id])
  order_items     PosOrderItem[]
  stock_movements StockMovement[]
  opname_items    StockOpnameItem[]
  promo_products  PromotionProduct[]

  @@unique([tenant_uuid, sku])
  @@index([tenant_uuid])
  @@index([outlet_id])
  @@index([category_id])
  @@index([unit_id])
  @@map("products")
}

// ─── STOCK MANAGEMENT ────────────────────────────────────────
model StockMovement {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_uuid     String   @db.Uuid
  outlet_id       String   @db.Uuid
  product_id      String   @db.Uuid
  type            String   // purchase_in, sale_out, opname_adjust, return, damage, transfer
  quantity        Int      // positive=in, negative=out
  cost_price      Decimal? @db.Decimal(12,2) // HPP saat pembelian
  stock_before    Int
  stock_after     Int
  reference       String?  // PO number, order_no, opname_id
  supplier_name   String?
  notes           String?
  created_by      String?  @db.Uuid
  created_at      DateTime @default(now())

  pesantren Pesantren      @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  created_by_user User?      @relation(fields: [created_by], references: [id])

  @@index([tenant_uuid])
  @@index([outlet_id])
  @@index([product_id])
  @@map("stock_movements")
}

model StockOpname {
  id          String    @id @default(uuid()) @db.Uuid
  tenant_uuid String    @db.Uuid
  outlet_id   String    @db.Uuid
  opname_no   String    @unique
  date        DateTime  @db.Date
  status      String    @default("draft") // draft, completed, cancelled
  notes       String?
  created_by  String?   @db.Uuid
  completed_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  pesantren Pesantren        @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet   @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  items     StockOpnameItem[]

  @@index([tenant_uuid])
  @@index([outlet_id])
  @@map("stock_opnames")
}

model StockOpnameItem {
  id             String @id @default(uuid()) @db.Uuid
  opname_id      String @db.Uuid
  product_id     String @db.Uuid
  system_stock   Int    // stok di sistem
  actual_stock   Int    // stok fisik
  difference     Int    // actual - system
  notes          String?

  opname  StockOpname @relation(fields: [opname_id], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [product_id], references: [id])

  @@unique([opname_id, product_id])
  @@index([opname_id])
  @@map("stock_opname_items")
}

// ─── PROMOTIONS ──────────────────────────────────────────────
model Promotion {
  id              String    @id @default(uuid()) @db.Uuid
  tenant_uuid     String    @db.Uuid
  outlet_id       String    @db.Uuid
  name            String
  description     String?
  discount_type   String    // percentage, fixed_amount
  discount_value  Decimal   @db.Decimal(12,2)
  min_purchase    Decimal   @default(0) @db.Decimal(12,2)
  max_discount    Decimal?  @db.Decimal(12,2) // cap for percentage
  apply_to        String    @default("all") // all, selected_products, category
  start_date      DateTime
  end_date        DateTime
  is_active       Boolean   @default(true)
  usage_limit     Int?      // null = unlimited
  usage_count     Int       @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  pesantren Pesantren          @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet     @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  products  PromotionProduct[]

  @@index([tenant_uuid])
  @@index([outlet_id])
  @@map("promotions")
}

model PromotionProduct {
  id           String @id @default(uuid()) @db.Uuid
  promotion_id String @db.Uuid
  product_id   String @db.Uuid

  promotion Promotion @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [product_id], references: [id])

  @@unique([promotion_id, product_id])
  @@map("promotion_products")
}

// ─── POS ─────────────────────────────────────────────────────
model PosSession {
  id              String    @id @default(uuid()) @db.Uuid
  tenant_uuid     String    @db.Uuid
  outlet_id       String    @db.Uuid
  cashier_id      String    @db.Uuid
  opening_balance Decimal   @default(0) @db.Decimal(12,2)
  closing_balance Decimal?  @db.Decimal(12,2)
  total_sales     Decimal   @default(0) @db.Decimal(12,2)
  total_orders    Int       @default(0)
  opened_at       DateTime  @default(now())
  closed_at       DateTime?
  notes           String?

  pesantren Pesantren      @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  cashier   User           @relation(fields: [cashier_id], references: [id])
  orders    PosOrder[]

  @@index([tenant_uuid])
  @@index([outlet_id])
  @@index([cashier_id])
  @@map("pos_sessions")
}

model PosOrder {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_uuid     String   @db.Uuid
  outlet_id       String   @db.Uuid
  order_no        String   @unique
  order_type      String   @default("sale") // sale, bill_payment, topup, withdrawal
  session_id      String?  @db.Uuid
  student_id      String?  @db.Uuid
  cashier_id      String   @db.Uuid
  bill_id         String?  @db.Uuid  // for bill_payment type
  subtotal        Decimal  @db.Decimal(12,2)
  discount        Decimal  @default(0) @db.Decimal(12,2)
  promo_id        String?  @db.Uuid
  promo_name      String?
  total           Decimal  @db.Decimal(12,2)
  payment_method  String   @default("wallet") // wallet, cash
  wallet_tx_ref   String?
  status          String   @default("completed") // completed, cancelled, refunded
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  pesantren Pesantren      @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  outlet    KoperasiOutlet @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  session   PosSession?    @relation(fields: [session_id], references: [id])
  student   Student?       @relation(fields: [student_id], references: [id])
  cashier   User           @relation("PosCashier", fields: [cashier_id], references: [id])
  items     PosOrderItem[]

  @@index([tenant_uuid])
  @@index([outlet_id])
  @@index([student_id])
  @@index([session_id])
  @@map("pos_orders")
}

model PosOrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  order_id     String  @db.Uuid
  product_id   String  @db.Uuid
  product_name String
  quantity     Int
  unit_price   Decimal @db.Decimal(12,2)
  cost_price   Decimal @default(0) @db.Decimal(12,2) // HPP snapshot
  discount     Decimal @default(0) @db.Decimal(12,2)
  subtotal     Decimal @db.Decimal(12,2)

  order   PosOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@map("pos_order_items")
}

model PpdbWave {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  name        String   // e.g., "Gelombang 1", "Jalur Prestasi"
  start_date  DateTime
  end_date    DateTime
  quota       Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([tenant_uuid, name])
  @@index([tenant_uuid])
  @@map("ppdb_waves")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  TENANT (PESANTREN)
// ═══════════════════════════════════════════════════════════════
model Pesantren {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  email     String?
  phone     String?
  address   String?
  logo      String?
  
  // Xendit / Payment
  xendit_sub_account_id String?
  platform_fee          Decimal  @default(0) @db.Decimal(12,2) // Total fee taken by platform (Surcharge + Deduction) for VA/Invoice
  surcharge_fee         Decimal  @default(0) @db.Decimal(12,2) // Extra amount added to student bill for VA/Invoice
  qris_platform_fee     Decimal  @default(0) @db.Decimal(12,2) // Total fee taken by platform for QRIS
  qris_surcharge_fee    Decimal  @default(0) @db.Decimal(12,2) // Extra amount added to student bill for QRIS
  qris_fee_is_percent   Boolean  @default(false)
  xendit_status         String   @default("inactive") // active, inactive
  
  // Subscription
  subscription_status   String   @default("trial") // trial, active, suspended, expired
  trial_duration_days   Int      @default(14)
  expired_at            DateTime?
  billing_cycle         String   @default("monthly") // monthly, yearly
  billing_day           Int      @default(1)
  billing_type          String   @default("per_student") // per_student, fixed
  price_per_student     Decimal  @default(0) @db.Decimal(12,2)
  fixed_billing_amount  Decimal  @default(0) @db.Decimal(12,2)
  billing_email         String?
  max_students          Int      @default(500)
  
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?
  
  calendar_type String @default("gregorian") // gregorian, hijri

  // Relations
  users              User[]
  students           Student[]
  teachers           Teacher[]
  classrooms         Classroom[]
  dormitories        Dormitory[]
  subjects           Subject[]
  academic_years     AcademicYear[]
  fee_categories     FeeCategory[]
  bills              Bill[]
  transactions       Transaction[]
  wallets            Wallet[]
  wallet_transactions WalletTransaction[]
  topup_logs         TopupLog[]
  attendances        Attendance[]
  tahfidz_records    TahfidzRecord[]
  violations         Violation[]
  health_records     HealthRecord[]
  permissions_record StudentPermission[]
  payrolls           Payroll[]
  payroll_items      PayrollItem[]
  settings           Setting[]
  posts              Post[]
  saas_invoices      SaasInvoice[]
  usage_logs         UsageLog[]
  academic_periods   AcademicPeriod[]
  question_banks     QuestionBank[]
  exams              Exam[]
  exam_schedules     ExamSchedule[]
  exam_results       ExamResult[]
  report_cards       ReportCard[]
  donation_disbursements DonationDisbursement[]
  teacher_attendances TeacherAttendance[]
  teaching_journals   TeachingJournal[]
  student_histories   StudentHistory[]
  daily_assignments   DailyAssignment[]
  assignment_grades   AssignmentGrade[]
  expenditures        Expenditure[]
  user_activities     UserActivity[]
  problem_tickets     ProblemTicket[]

  @@map("pesantrens")
}

// ═══════════════════════════════════════════════════════════════
//  USERS & ROLES
// ═══════════════════════════════════════════════════════════════
enum Role {
  SUPER_ADMIN
  ADMIN_PESANTREN
  FINANCE_PESANTREN
  STAFF_PESANTREN
  USTAD
  WALI_SANTRI
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_uuid   String?   @db.Uuid
  name          String
  email         String?   @unique
  phone         String?   @unique
  password      String
  role          Role      @default(STAFF_PESANTREN)
  is_active     Boolean   @default(true)
  base_salary   Decimal   @default(0) @db.Decimal(12,2)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  pesantren     Pesantren?  @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  teacher       Teacher?
  payroll_items PayrollItem[]
  refresh_tokens RefreshToken[]
  notifications UserNotification[]
  activities    UserActivity[]
  created_tickets ProblemTicket[] @relation("TicketCreator")
  ticket_messages ProblemTicketMessage[]

  @@index([tenant_uuid])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  token       String   @unique
  expires_at  DateTime
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model UserNotification {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  type        String
  title       String
  message     String
  action_data Json?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_notifications")
}

// ═══════════════════════════════════════════════════════════════
//  ACADEMIC
// ═══════════════════════════════════════════════════════════════
model AcademicYear {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  name        String
  start_date  DateTime
  end_date    DateTime
  is_active   Boolean  @default(false)
  active_term Int      @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren  Pesantren  @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  students   Student[]
  classrooms Classroom[]
  periods    AcademicPeriod[]
  exams      Exam[]
  report_cards ReportCard[]

  @@unique([tenant_uuid, name])
  @@index([tenant_uuid])
  @@map("academic_years")
}

model AcademicPeriod {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  academic_year_id String   @db.Uuid
  name             String   // Semester Ganjil, Catur Wulan 1, etc.
  start_date       DateTime
  end_date         DateTime
  is_active        Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  pesantren     Pesantren     @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  academic_year AcademicYear  @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  report_cards  ReportCard[]
  exams         Exam[]

  @@unique([tenant_uuid, academic_year_id, name])
  @@index([tenant_uuid])
  @@map("academic_periods")
}

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  name        String
  code        String?
  category    String?  // diniyah, formal, tahfidz
  kkm         Int      @default(70)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren   Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  schedules   Schedule[]
  question_banks QuestionBank[]
  exam_schedules ExamSchedule[]
  report_details ReportCardDetail[]
  daily_assignments DailyAssignment[]

  @@unique([tenant_uuid, code])
  @@index([tenant_uuid])
  @@map("subjects")
}

model Classroom {
  id                   String   @id @default(uuid()) @db.Uuid
  tenant_uuid          String   @db.Uuid
  name                 String
  level                String?
  academic_year_id     String?  @db.Uuid
  homeroom_teacher_id  String?  @db.Uuid
  capacity             Int      @default(40)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  pesantren      Pesantren     @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  academic_year  AcademicYear? @relation(fields: [academic_year_id], references: [id])
  homeroom       Teacher?      @relation(fields: [homeroom_teacher_id], references: [id])
  students       Student[]
  schedules      Schedule[]
  exam_schedules ExamSchedule[]
  report_cards   ReportCard[]
  daily_assignments DailyAssignment[]

  @@unique([tenant_uuid, name, academic_year_id])
  @@index([tenant_uuid])
  @@map("classrooms")
}

model Dormitory {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  name        String
  mushrif_name String?
  capacity    Int      @default(100)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren       @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  rooms     DormitoryRoom[]
  students  Student[]

  @@unique([tenant_uuid, name])
  @@index([tenant_uuid])
  @@map("dormitories")
}

model DormitoryRoom {
  id           String   @id @default(uuid()) @db.Uuid
  dormitory_id String   @db.Uuid
  name         String
  capacity     Int      @default(10)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  dormitory Dormitory @relation(fields: [dormitory_id], references: [id], onDelete: Cascade)
  students  Student[]

  @@map("dormitory_rooms")
}

model Schedule {
  id           String   @id @default(uuid()) @db.Uuid
  tenant_uuid  String   @db.Uuid
  classroom_id String   @db.Uuid
  subject_id   String   @db.Uuid
  teacher_id   String?  @db.Uuid
  day_of_week  Int      // 0=Sunday, 1=Monday...
  start_time   String
  end_time     String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  classroom   Classroom   @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subject_id], references: [id])
  teacher     Teacher?    @relation(fields: [teacher_id], references: [id])
  attendances Attendance[]
  teacher_attendances TeacherAttendance[]
  teaching_journals   TeachingJournal[]

  @@index([tenant_uuid])
  @@map("schedules")
}

// ═══════════════════════════════════════════════════════════════
//  SANTRI (STUDENT)
// ═══════════════════════════════════════════════════════════════
model Student {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  nis              String?
  nisn             String?
  nik              String?
  name             String
  gender           String?  // L, P
  birth_place      String?
  birth_date       DateTime?
  address          String?
  photo            String?
  
  father_name      String?
  father_job       String?
  father_address   String?
  mother_name      String?
  mother_job       String?
  mother_address   String?
  parent_phone     String?
  parent_email     String?
  
  // Fisik & Pendidikan
  last_education   String?
  weight           Int?
  height           Int?

  // Alamat Detil
  country          String?  @default("Indonesia")
  province         String?
  city             String?
  district         String?
  village          String?

  // Dokumen
  file_kk          String?
  file_ijazah      String?
  file_akta        String?
  file_others      String?
  
  academic_year_id    String?  @db.Uuid
  classroom_id        String?  @db.Uuid
  dormitory_id        String?  @db.Uuid
  dormitory_room_id   String?  @db.Uuid
  tahfidz_teacher_id  String?  @db.Uuid
  
  status           String   @default("CALON") // CALON, AKTIF, ALUMNI, BOYONG, KELUAR
  entry_year       Int?
  graduation_date  DateTime?
  rfid             String?
  fingerprint_id   String?
  
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  deleted_at       DateTime?

  pesantren       Pesantren      @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  academic_year   AcademicYear?  @relation(fields: [academic_year_id], references: [id])
  classroom       Classroom?     @relation(fields: [classroom_id], references: [id])
  dormitory       Dormitory?     @relation(fields: [dormitory_id], references: [id])
  dormitory_room  DormitoryRoom? @relation(fields: [dormitory_room_id], references: [id])
  tahfidz_teacher Teacher?       @relation("TahfidzStudents", fields: [tahfidz_teacher_id], references: [id])
  
  wallet           Wallet?
  bills            Bill[]
  transactions     Transaction[]
  attendances      Attendance[]
  tahfidz_records  TahfidzRecord[]
  violations       Violation[]
  health_records   HealthRecord[]
  student_permissions StudentPermission[]
  exam_results     ExamResult[]
  report_cards     ReportCard[]
  histories        StudentHistory[]
  assignment_grades AssignmentGrade[]

  @@unique([tenant_uuid, nis])
  @@index([tenant_uuid])
  @@index([parent_phone])
  @@map("students")
}

// ═══════════════════════════════════════════════════════════════
//  GURU (TEACHER)
// ═══════════════════════════════════════════════════════════════
model Teacher {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  user_id     String?  @unique @db.Uuid
  nip         String?
  nik         String?
  name        String
  phone       String?
  address     String?
  birth_place String?
  birth_date  DateTime?
  status      String   @default("active") // active, inactive, resigned
  stay_type   String?  // mukim, non-mukim
  photo       String?
  is_tahfidz_teacher Boolean @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  pesantren       Pesantren     @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [user_id], references: [id])
  classrooms      Classroom[]
  schedules       Schedule[]
  tahfidz_students Student[]    @relation("TahfidzStudents")
  payroll_items    PayrollItem[]
  question_banks   QuestionBank[]
  exam_paper_schedules   ExamSchedule[] @relation("ExamPaperTeacher")
  exam_supervisor_schedules ExamSchedule[] @relation("ExamSupervisor")
  attendances      TeacherAttendance[]
  teaching_journals TeachingJournal[]
  daily_assignments DailyAssignment[]

  @@unique([tenant_uuid, nip])
  @@index([tenant_uuid])
  @@map("teachers")
}

// ═══════════════════════════════════════════════════════════════
//  ATTENDANCE
// ═══════════════════════════════════════════════════════════════
model Attendance {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  student_id  String   @db.Uuid
  schedule_id String?  @db.Uuid
  date        DateTime @db.Date
  status      String   // hadir, izin, sakit, alpha
  check_in    DateTime?
  check_out   DateTime?
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren  @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student   Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)
  schedule  Schedule?  @relation(fields: [schedule_id], references: [id])

  @@unique([student_id, schedule_id, date])
  @@index([tenant_uuid])
  @@index([student_id])
  @@map("attendances")
}

model TahfidzRecord {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  student_id  String   @db.Uuid
  teacher_id  String?  @db.Uuid
  
  category    String   @default("QURAN") // QURAN, NADHOM
  
  // For Quran: Surah Name | For Nadhom: Kitab Name
  title       String   
  
  // For Quran: Ayah | For Nadhom: Bait/Line
  from        Int?
  to          Int?
  juz         Int?     // Specific to Quran
  
  type        String?  // setoran, murajaah
  status      String?  // lancar, tidak_lancar
  date        DateTime @db.Date
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([tenant_uuid])
  @@index([student_id])
  @@map("tahfidz_records")
}

model Violation {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  student_id  String   @db.Uuid
  type        String
  description String?
  points      Int      @default(0)
  date        DateTime @db.Date
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([tenant_uuid])
  @@map("violations")
}

model HealthRecord {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  student_id  String   @db.Uuid
  type        String
  description String?
  treatment   String?
  date        DateTime @db.Date
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([tenant_uuid])
  @@map("health_records")
}

model StudentPermission {
  id          String    @id @default(uuid()) @db.Uuid
  tenant_uuid String    @db.Uuid
  student_id  String    @db.Uuid
  type        String    // pulang, sakit, keperluan
  reason      String?
  start_date  DateTime  @db.Date
  end_date    DateTime? @db.Date
  status      String    @default("pending") // pending, approved, rejected
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([tenant_uuid])
  @@map("student_permissions")
}

// ═══════════════════════════════════════════════════════════════
//  PAYMENT & BILLING
// ═══════════════════════════════════════════════════════════════
model FeeCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  name        String
  type        String   @default("monthly") // monthly, yearly, once
  amount      Decimal  @db.Decimal(12,2)
  description String?
  is_active   Boolean  @default(true)
  due_day     Int?     @default(10)
  image_url   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  bills     Bill[]
  transactions Transaction[]
  disbursements DonationDisbursement[]

  @@unique([tenant_uuid, name])
  @@index([tenant_uuid])
  @@map("fee_categories")
}

model Bill {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_uuid     String   @db.Uuid
  student_id      String   @db.Uuid
  fee_category_id String   @db.Uuid
  amount          Decimal  @db.Decimal(12,2)
  amount_paid     Decimal  @default(0) @db.Decimal(12,2)
  period          String?  // 2026-01, 2026-02, etc
  due_date        DateTime @db.Date
  status          String   @default("pending") // pending, partial, paid, overdue
  notes           String?
  notified_at     DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  pesantren    Pesantren    @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  fee_category FeeCategory  @relation(fields: [fee_category_id], references: [id])
  transactions Transaction[]

  @@unique([student_id, fee_category_id, period])
  @@index([tenant_uuid])
  @@index([student_id])
  @@index([status])
  @@map("bills")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_uuid     String   @db.Uuid
  reference_no    String   @unique
  student_id      String   @db.Uuid
  bill_id         String?  @db.Uuid
  fee_category_id String?  @db.Uuid
  amount_paid     Decimal  @db.Decimal(12,2)
  payment_date    DateTime @default(now())
  payment_method  String   @default("cash") // cash, transfer, gateway
  payment_channel String?
  xendit_invoice_id String?
  status          String   @default("pending") // pending, success, failed
  evidence_url    String?
  platform_fee    Decimal  @default(0) @db.Decimal(12,2)
  surcharge_fee   Decimal  @default(0) @db.Decimal(12,2)
  xendit_fee      Decimal  @default(0) @db.Decimal(12,2)
  net_amount      Decimal  @default(0) @db.Decimal(12,2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  pesantren    Pesantren    @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  bill         Bill?        @relation(fields: [bill_id], references: [id])
  fee_category FeeCategory? @relation(fields: [fee_category_id], references: [id])

  @@index([tenant_uuid])
  @@index([student_id])
  @@map("transactions")
}

// ═══════════════════════════════════════════════════════════════
//  E-WALLET
// ═══════════════════════════════════════════════════════════════
model Wallet {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  student_id  String   @unique @db.Uuid
  balance     Decimal  @default(0) @db.Decimal(12,2)
  pin         String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren    Pesantren          @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [student_id], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  topup_logs   TopupLog[]

  @@index([tenant_uuid])
  @@map("wallets")
}

model WalletTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  tenant_uuid    String   @db.Uuid
  wallet_id      String   @db.Uuid
  type           String   // deposit, withdrawal, transfer_in, transfer_out, payment
  amount         Decimal  @db.Decimal(12,2)
  balance_before Decimal  @db.Decimal(12,2)
  balance_after  Decimal  @db.Decimal(12,2)
  reference      String?
  description    String?
  created_at     DateTime @default(now())

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  wallet    Wallet    @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([tenant_uuid])
  @@index([wallet_id])
  @@map("wallet_transactions")
}

model TopupLog {
  id          String    @id @default(uuid()) @db.Uuid
  tenant_uuid String    @db.Uuid
  wallet_id   String    @db.Uuid
  external_id String    @unique
  xendit_id   String?
  amount      Decimal   @db.Decimal(12,2)
  status      String    @default("pending") // pending, success, failed, pending_bill
  notes       String?
  paid_at     DateTime?
  platform_fee Decimal   @default(0) @db.Decimal(12,2)
  surcharge_fee Decimal   @default(0) @db.Decimal(12,2)
  xendit_fee    Decimal   @default(0) @db.Decimal(12,2)
  net_amount    Decimal   @default(0) @db.Decimal(12,2)
  created_at  DateTime  @default(now())

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  wallet    Wallet    @relation(fields: [wallet_id], references: [id], onDelete: Cascade)


// ═══════════════════════════════════════════════════════════════
//  EXAM & ACADEMIC MANAGEMENT
// ═══════════════════════════════════════════════════════════════
model QuestionBank {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_uuid String   @db.Uuid
  subject_id  String   @db.Uuid
  teacher_id  String   @db.Uuid
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pesantren Pesantren @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subject_id], references: [id])
  teacher   Teacher   @relation(fields: [teacher_id], references: [id])
  questions Question[]
  exam_schedules ExamSchedule[]

  @@index([tenant_uuid])
  @@map("question_banks")
}

model Question {
  id               String   @id @default(uuid()) @db.Uuid
  question_bank_id String   @db.Uuid
  type             String   // multiple_choice, essay
  content          String   // Question text/HTML
  options          Json?    // Array of options for multiple choice
  correct_answer   String?  // The correct option or answer key
  points           Int      @default(10)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  question_bank QuestionBank @relation(fields: [question_bank_id], references: [id], onDelete: Cascade)
  exam_questions ExamQuestion[]

  @@index([question_bank_id])
  @@map("questions")
}

model Exam {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  academic_year_id String   @db.Uuid
  period_id        String?  @db.Uuid
  name             String   // UTS, UAS, Ulangan Harian, etc.
  start_date       DateTime
  end_date         DateTime
  status           String   @default("draft") // draft, published, ongoing, finished
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  pesantren     Pesantren       @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  academic_year AcademicYear    @relation(fields: [academic_year_id], references: [id])
  period        AcademicPeriod? @relation(fields: [period_id], references: [id])
  schedules     ExamSchedule[]

  @@index([tenant_uuid])
  @@map("exams")
}

model ExamSchedule {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  exam_id          String   @db.Uuid
  subject_id       String   @db.Uuid
  question_bank_id String?  @db.Uuid
  classroom_id     String   @db.Uuid
  date             DateTime @db.Date
  start_time       String
  end_time         String
  teacher_id       String?  @db.Uuid // Teacher responsible for the exam paper
  supervisor_id    String?  @db.Uuid // Teacher guarding the room
  status           String   @default("pending") // pending, submitted, approved
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  pesantren     Pesantren     @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  exam          Exam          @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subject_id], references: [id])
  question_bank QuestionBank? @relation(fields: [question_bank_id], references: [id])
  classroom     Classroom     @relation(fields: [classroom_id], references: [id])
  teacher       Teacher?      @relation("ExamPaperTeacher", fields: [teacher_id], references: [id])
  supervisor    Teacher?      @relation("ExamSupervisor", fields: [supervisor_id], references: [id])
  results       ExamResult[]
  questions     ExamQuestion[]

  @@index([tenant_uuid])
  @@map("exam_schedules")
}

model ExamResult {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  exam_schedule_id String   @db.Uuid
  student_id       String   @db.Uuid
  score            Decimal  @db.Decimal(5,2)
  answers          Json?    // Student's answers
  notes            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  pesantren     Pesantren    @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  exam_schedule ExamSchedule @relation(fields: [exam_schedule_id], references: [id], onDelete: Cascade)
  student       Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([exam_schedule_id, student_id])
  @@index([tenant_uuid])
  @@map("exam_results")
}

model ExamQuestion {
  id               String   @id @default(uuid()) @db.Uuid
  exam_schedule_id String   @db.Uuid
  question_id      String   @db.Uuid
  order            Int      @default(0)

  exam_schedule    ExamSchedule @relation(fields: [exam_schedule_id], references: [id], onDelete: Cascade)
  question         Question     @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([exam_schedule_id, question_id])
  @@map("exam_questions")
}

model ReportCard {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_uuid      String   @db.Uuid
  student_id       String   @db.Uuid
  academic_year_id String   @db.Uuid
  period_id        String?  @db.Uuid
  classroom_id     String   @db.Uuid
  total_score      Decimal? @db.Decimal(8,2)
  average_score    Decimal? @db.Decimal(5,2)
  rank             Int?
  notes_homeroom   String?
  status           String   @default("draft") // draft, published
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  pesantren     Pesantren       @relation(fields: [tenant_uuid], references: [id], onDelete: Cascade)
  student       Student         @relation(fields: [student_id], references: [id], onDelete: Cascade)
  academic_year AcademicYear    @relation(fields: [academic_year_id], references: [id])
  period        AcademicPeriod? @relation(fields: [period_id], references: [id])
  classroom     Classroom       @relation(fields: [classroom_id], references: [id])
  details       ReportCardDetail[]

  @@unique([student_id, academic_year_id, period_id])
  @@index([tenant_uuid])
  @@map("report_cards")
}

model ReportCardDetail {
  id             String   @id @default(uuid()) @db.Uuid
  report_card_id String   @db.Uuid
  subject_id     String   @db.Uuid
  score          Decimal  @db.Decimal(5,2)
  predicate      String?  // A, B, C, D
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  report_card ReportCard @relation(fields: [report_card_id], references: [id], onDelete: Cascade)
  subject     Subject    @relation(fields: [subject_id], references: [id])

  @@unique([report_card_id, subject_id])
  @@map("report_card_details")
}


